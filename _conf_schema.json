{
    "service_base_url": {
        "description": "服务地址",
        "hint": "apple-music-downloader-bot 的 AstrBot API 地址，例如 http://127.0.0.1:27198",
        "type": "string",
        "default": "http://127.0.0.1:27198"
    },
    "service_token": {
        "description": "服务鉴权令牌",
        "hint": "可选。若服务端设置了 ASTRBOT_API_TOKEN，这里填写同一个 token",
        "type": "string",
        "default": ""
    },
    "search_limit": {
        "description": "搜索返回数量",
        "hint": "每次搜索展示的条目数",
        "type": "int",
        "slider": {
            "min": 1,
            "max": 20,
            "step": 1
        },
        "default": 8
    },
    "selection_timeout": {
        "description": "多轮会话超时(秒)",
        "hint": "选歌/二级选择等待时间，超时会自动清理",
        "type": "int",
        "slider": {
            "min": 30,
            "max": 300,
            "step": 10
        },
        "default": 90
    },
    "auto_parse_url": {
        "description": "自动识别链接",
        "hint": "开启后会自动识别 Apple Music 链接并执行",
        "type": "bool",
        "default": true
    },
    "default_transfer_mode": {
        "description": "默认传输模式",
        "hint": "专辑/歌单/电台默认发送方式",
        "type": "string",
        "options": [
            "one(逐个)",
            "zip(压缩包)"
        ],
        "default": "one(逐个)"
    },
    "temp_dir": {
        "description": "临时目录",
        "hint": "留空时使用 AstrBot 插件 data 目录下的 temp",
        "type": "string",
        "default": ""
    },
    "clean_cache_on_reload": {
        "description": "重载时清理临时目录",
        "hint": "仅清理插件临时目录，不会清理下载器主目录",
        "type": "bool",
        "default": false
    },
    "proxy": {
        "description": "HTTP 代理",
        "hint": "例如 http://127.0.0.1:7890，留空表示直连",
        "type": "string",
        "default": ""
    },
    "path_map": {
        "description": "路径映射",
        "hint": "服务端路径=>插件可见路径；多条用 ; 或换行分隔。例: /srv/amdl/downloads=>/mnt/amdl/downloads",
        "type": "string",
        "default": ""
    },
    "default_storefront": {
        "description": "默认区服",
        "hint": "如 us、jp、cn",
        "type": "string",
        "default": "us"
    }
}
